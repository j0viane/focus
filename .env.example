# Copy to `.env` at the repo root (never commit `.env`).
# LLM caption labeling is opt-in and off by default.

# FOCUS_LLM_ENABLED=false
# FOCUS_LLM_PROVIDER=openai
# FOCUS_LLM_API_KEY=
# FOCUS_LLM_MODEL=
# FOCUS_LLM_BASE_URL=
# FOCUS_LLM_CONCURRENCY=4

# Provider: openai | anthropic | ollama
# Captions stay off until you pass --llm-captions or set focus.llmCaptions /
# .focus.toml [llm] captions=true. FOCUS_LLM_ENABLED alone does not turn them on.
# Ollama (no paid key): install Ollama, `ollama pull qwen2.5:7b`, then:
#   FOCUS_LLM_PROVIDER=ollama
#   FOCUS_LLM_MODEL=qwen2.5:7b
# Optional: FOCUS_LLM_BASE_URL=http://127.0.0.1:11434/v1
# Optional: FOCUS_LLM_CONCURRENCY=4  (parallel caption labels; 1–16)
# Captions only — never invents dependency edges. See docs/PRIVACY.md.
